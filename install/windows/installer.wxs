<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="*"
           Name="AirPlayReceiver"
           Language="1033"
           Version="1.0.0"
           Manufacturer="AirPlayReceiver"
           UpgradeCode="12345678-1234-1234-1234-123456789012">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"/>

    <MediaTemplate/>

    <!-- REQUIRED for UI install folder selection -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER"/>

    <!-- USE FULL INSTALL WIZARD UI -->
    <UIRef Id="WixUI_InstallDir"/>

    <Feature Id="MainFeature" Level="1">
      <ComponentRef Id="MainExe"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>

    <!-- INSTALL PATH -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="AirPlayReceiver"/>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="AirPlayReceiver"/>
      </Directory>

      <Directory Id="DesktopFolder"/>
    </Directory>

    <!-- MAIN EXE -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExe" Guid="*">
        <File Source="dist\AirPlayReceiver\AirPlayReceiver.exe"
              KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <RegistryValue
    Root="HKCU"
    Key="Software\Microsoft\Windows\CurrentVersion\Run"
    Name="AirPlayUpdater"
    Type="string"
    Value="[INSTALLFOLDER]Updater.exe"/>

    <!-- START MENU SHORTCUT -->
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="StartMenuLink"
                   Name="AirPlayReceiver"
                   Target="[INSTALLFOLDER]AirPlayReceiver.exe"
                   WorkingDirectory="INSTALLFOLDER"/>
        <RemoveFolder Id="AppMenuFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\AirPlayReceiver"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- DESKTOP SHORTCUT -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*">
        <Shortcut Id="DesktopLink"
                   Name="AirPlayReceiver"
                   Target="[INSTALLFOLDER]AirPlayReceiver.exe"
                   WorkingDirectory="INSTALLFOLDER"/>
        <RegistryValue Root="HKCU"
                       Key="Software\AirPlayReceiver"
                       Name="desktop"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

  </Product>
</Wix>